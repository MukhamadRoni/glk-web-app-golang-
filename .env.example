# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Security
JWT_SECRET=changeme_in_production_use_a_long_random_string
